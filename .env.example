# OpenAI (필수)
OPENAI_API_KEY=sk-...

# Supabase (Free tier)
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# Langfuse (cloud free tier)
# LANGFUSE_HOST: 가입 시 선택한 region에 맞게 설정
#   EU: https://cloud.langfuse.com  (default)
#   US: https://us.cloud.langfuse.com
#   JP: https://jp.cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# HuggingFace (pyannote.audio 모델 다운로드용 — VAD/diarization 단계에서 필요)
HUGGINGFACE_TOKEN=hf_...

# MLflow (eval 결과 저장 위치 — 비어 두면 mlflow native default(file:./mlruns) 사용)
MLFLOW_TRACKING_URI=file:./mlruns
